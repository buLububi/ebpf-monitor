{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "各容器 CPU 使用情况",
      "description": "展示不同容器的 CPU 负载变化。数值越高，说明该容器越占用计算资源。",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_cpu_usage_usec[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "各容器当前内存占用",
      "description": "展示不同容器当前的内存使用量，单位为 MiB，更符合日常理解。",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "mbytes"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_memory_current_bytes / 1024 / 1024)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "各容器线程切换频率",
      "description": "表示容器中的程序每秒发生多少次线程切换，可反映调度活跃程度。",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_sched_switch_total[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "各容器线程唤醒频率",
      "description": "表示容器中的线程每秒被唤醒多少次，可用于观察程序活跃程度。",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_sched_wakeup_total[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Web 类容器 CPU 使用情况",
      "description": "专门观察 Web 服务类容器（如 nginx）的 CPU 负载。",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_cpu_usage_usec{container_role=\"web\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Web 类容器线程切换频率",
      "description": "用于观察 Web 服务的调度活跃度，频率越高说明线程切换越频繁。",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_sched_switch_total{container_role=\"web\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Web 类容器最近一次等待 CPU 时间",
      "description": "表示 Web 类容器最近一次等待 CPU 的时间，单位为毫秒，越高说明越容易卡顿。",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_sched_latency_last_us{container_role=\"web\"} / 1000)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "缓存/数据库类容器 CPU 使用情况",
      "description": "专门观察缓存或数据库类容器（如 redis）的 CPU 负载。",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_cpu_usage_usec{container_role=\"cache_db\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "缓存/数据库类容器当前内存占用",
      "description": "展示缓存或数据库类容器当前的内存消耗，单位为 MiB。",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "mbytes"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_memory_current_bytes{container_role=\"cache_db\"} / 1024 / 1024)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "缓存/数据库类容器平均等待 CPU 时间",
      "description": "表示缓存或数据库类容器线程平均等待 CPU 的时间，单位为毫秒，越高表示调度压力越大。",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_sched_latency_avg_us{container_role=\"cache_db\"} / 1000)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "缓存/数据库类容器最大卡顿时间",
      "description": "表示缓存或数据库类容器出现过的最大等待 CPU 时间，单位为毫秒，可用于观察突发卡顿。",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (container_sched_latency_max_us{container_role=\"cache_db\"} / 1000)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "缓存/数据库类容器内存页分配频率",
      "description": "表示缓存或数据库类容器每秒触发多少次内存页分配，可辅助判断内存活动情况。",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "sum by (container) (rate(container_mm_page_alloc_total{container_role=\"cache_db\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "当前已启用的 eBPF 监测点数量",
      "description": "表示当前系统已挂载的 eBPF attach points 数量，用于体现监测覆盖范围。",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 40 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "ebpf_module_attach_points_total{module=\"cpu_mem_multi\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU 使用最高的容器",
      "description": "自动筛选 CPU 使用最高的容器，便于快速发现高负载对象。",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 40 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "topk(5, sum by (container) (rate(container_cpu_usage_usec[1m])))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "ebpf",
    "container",
    "classified",
    "human-friendly"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Container Classified Monitor FINAL",
  "uid": "container-classified-final",
  "version": 3
}
