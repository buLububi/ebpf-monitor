    {
      "id": 10,
      "type": "table",
      "title": "容器健康状态表",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "((max by (container, container_role) (container_cpu_usage_usec{container_role=~\"$role\"} * 0)) + on(container) group_left() (max by (container) (ALERTS{alertstate=\"firing\",container=~\".+\"} * 1))) or (max by (container, container_role) (container_cpu_usage_usec{container_role=~\"$role\"} * 0))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "job": true,
              "instance": true,
              "host_pid": true,
              "mnt_ns": true,
              "net_ns": true,
              "pid_ns": true,
              "cgroup_path": true
            },
            "renameByName": {
              "container": "容器名称",
              "container_role": "容器类型",
              "alertname": "告警名称",
              "alertstate": "状态",
              "severity": "级别",
              "Value": "健康状态"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "健康状态"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "正常",
                        "color": "green"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "告警",
                        "color": "red"
                      }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": 0
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "description": "绿色表示健康，红色表示异常。点击容器可进入详情页。"
    },
