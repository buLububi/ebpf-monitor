        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "(count(count by (container) (container_cpu_usage_usec{container_role=~\"$role\"})) OR vector(0)) - (count(count by (container) (ALERTS{alertstate=\"firing\",container=~\".+\"})) OR vector(0))",
          "refId": "A",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
