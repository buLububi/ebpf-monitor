{
  "uid": "ebpf-container-customer-detail",
  "title": "容器性能详情",
  "schemaVersion": 42,
  "version": 304,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "容器",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(container_cpu_usage_usec, container)",
        "refresh": 1
      }
    ]
  },
  "links": [
    {
      "title": "返回容器总览",
      "url": "/d/ebpf-container-customer-overview/ebpf-container-overview",
      "type": "link",
      "keepTime": true
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "当前 CPU 活跃度",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "max(rate(container_cpu_usage_usec{container=\"$container\"}[1m])) OR vector(0)",
          "refId": "A",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
