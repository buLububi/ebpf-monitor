    {
      "id": 10,
      "type": "table",
      "title": "容器实时健康排行：点击容器可进入详情",
      "description": "把 CPU 活跃度、内存占用、IO 延迟合成一个客户可理解的实时排行。点击容器名称可进入该容器详情页。",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(20, rate(container_cpu_usage_usec{container_role=~\"$role\"}[1m]) + container_memory_current_bytes{container_role=~\"$role\"} / 1024 / 1024 / 1024 + container_io_latency_avg_us{container_role=~\"$role\"} / 1000)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "container": "容器名称",
              "container_role": "容器类型",
              "Value": "当前值"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          "links": [
            {
              "title": "查看该容器详情",
              "url": "/d/container-detail-by-name/container-detail?var-container=${__data.fields[\"容器名称\"]}&from=now-15m&to=now"
            }
          ],
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
