groups:
  - name: ebpf_container_alerts
    rules:
      - alert: 容器CPU负载过高
        expr: sum by (container) (rate(container_cpu_usage_usec[1m])) > 50000
        for: 30s
        labels:
          severity: 一般
        annotations:
          summary: 检测到容器CPU负载过高
          display_summary: 容器 {{ $labels.container }} CPU负载过高
          description: 该容器最近30秒CPU使用持续偏高，需要关注负载情况。

      - alert: 容器平均调度等待时间过高
        expr: sum by (container) (container_sched_latency_avg_us) > 300000
        for: 30s
        labels:
          severity: 一般
        annotations:
          summary: 检测到容器平均调度等待时间过高
          display_summary: 容器 {{ $labels.container }} 平均调度等待时间过高
          description: 说明该容器线程平均等待CPU时间偏长，可能存在资源竞争。

      - alert: 容器最大调度等待时间异常
        expr: max by (container) (max_over_time(container_sched_latency_last_us[5m])) > 5000000
        for: 15s
        labels:
          severity: 严重
        annotations:
          summary: 检测到容器最近5分钟最大调度等待时间异常
          display_summary: 容器 {{ $labels.container }} 最近5分钟最大调度等待时间异常
          description: 说明该容器最近5分钟内出现了明显的调度抖动或突发等待。

      - alert: Web类容器线程唤醒频率异常
        expr: sum by (container) (rate(container_sched_wakeup_total{container_role="web"}[1m])) > 100
        for: 15s
        labels:
          severity: 一般
        annotations:
          summary: 检测到Web类容器线程唤醒频率异常
          display_summary: Web类容器 {{ $labels.container }} 线程唤醒频率异常
          description: 说明Web服务在单位时间内被过于频繁唤醒，可能存在异常流量或请求抖动。

      - alert: 缓存数据库类容器调度压力过大
        expr: sum by (container) (container_sched_latency_avg_us{container_role="cache_db"}) > 400000
        for: 30s
        labels:
          severity: 严重
        annotations:
          summary: 检测到缓存/数据库类容器调度压力过大
          display_summary: 缓存/数据库类容器 {{ $labels.container }} 调度压力过大
          description: 说明缓存或数据库类容器平均调度等待时间持续偏高，需要检查CPU限制或高并发负载。

      - alert: 监控链路中断
        expr: up{job="ebpf_container_cpu_mem"} == 0
        for: 15s
        labels:
          severity: 严重
        annotations:
          summary: 检测到容器监控链路中断
          display_summary: 容器监控链路中断
          description: Prometheus无法抓取eBPF容器监控指标，请检查exporter或监控进程。

      - alert: 容器IO平均延迟过高
        expr: container_io_latency_avg_us > 800
        for: 30s
        labels:
          severity: 严重
        annotations:
          summary: 检测到容器IO平均延迟过高
          display_summary: 容器 {{ $labels.container }} IO平均延迟过高
          description: 当前时间窗口内，该容器IO平均响应延迟持续偏高，可能存在磁盘压力或阻塞。

      - alert: 容器IO最大延迟异常
        expr: container_io_latency_max_us > 2000
        for: 30s
        labels:
          severity: 严重
        annotations:
          summary: 检测到容器IO最大延迟异常
          display_summary: 容器 {{ $labels.container }} IO最大延迟异常
          description: 当前时间窗口内，该容器出现明显IO延迟峰值，可能存在突发阻塞或磁盘抖动。

      - alert: Web类容器读取压力过大
        expr: increase(container_io_stat_rbytes{container_role="web"}[1m]) > 20000000
        for: 30s
        labels:
          severity: 警告
        annotations:
          summary: 检测到Web类容器读取压力过大
          display_summary: Web容器 {{ $labels.container }} 读取压力过大
          description: 最近1分钟内读取流量持续偏高，可能存在高并发访问或资源被频繁拉取。

      - alert: 缓存数据库类容器磁盘写入压力过大
        expr: increase(container_io_stat_wbytes{container_role="cache_db"}[1m]) > 5000000
        for: 30s
        labels:
          severity: 严重
        annotations:
          summary: 检测到缓存/数据库类容器磁盘写入压力过大
          display_summary: 缓存/数据库容器 {{ $labels.container }} 写入压力过大
          description: 最近1分钟内磁盘写入增量持续偏高，可能存在数据持久化压力或写入热点。

      - alert: 容器IO读操作异常频繁
        expr: container_io_read_calls > 1000
        for: 30s
        labels:
          severity: 警告
        annotations:
          summary: 检测到容器IO读操作异常频繁
          display_summary: 容器 {{ $labels.container }} IO读操作频繁
          description: 当前时间窗口内读操作次数过多，可能存在频繁小文件读取或缓存失效。

      - alert: 容器IO写操作异常频繁
        expr: container_io_write_calls > 500
        for: 30s
        labels:
          severity: 警告
        annotations:
          summary: 检测到容器IO写操作异常频繁
          display_summary: 容器 {{ $labels.container }} IO写操作频繁
          description: 当前时间窗口内写操作次数过多，可能存在日志刷盘频繁或写入压力集中。

      - alert: IO监控链路中断
        expr: up{job="ebpf_container_io"} == 0
        for: 15s
        labels:
          severity: 严重
        annotations:
          summary: 检测到IO监控链路中断
          display_summary: 容器IO监控链路中断
          description: Prometheus无法抓取IO模块指标，请检查io monitor进程、io exporter或Prometheus抓取配置。

